                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('total');",
                  "    pm.expect(jsonData.data).to.have.property('page');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/plan/annual?page=1&pageSize=10&year=2024&status=all",
              "host": ["{{baseUrl}}"],
              "path": ["plan", "annual"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "year",
                  "value": "2024"
                },
                {
                  "key": "status",
                  "value": "all"
                }
              ]
            },
