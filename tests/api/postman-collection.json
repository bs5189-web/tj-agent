        {
          "name": "1.1 创建年度计划",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('响应状态码为200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('返回计划ID', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "});",
                  "pm.test('计划状态为待审批', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"2024年度办公设备采购计划\",\n    \"budget\": 500000,\n    \"category\": \"goods\",\n    \"department\": \"技术部\",\n    \"year\": 2024,\n    \"items\": [\n        {\n            \"name\": \"联想ThinkPad笔记本\",\n            \"specification\": \"ThinkPad X1 Carbon\",\n            \"quantity\": 10,\n            \"unitPrice\": 10000,\n            \"totalPrice\": 100000\n        },\n        {\n            \"name\": \"Dell显示器\",\n            \"specification\": \"Dell U2720Q\",\n            \"quantity\": 20,\n            \"unitPrice\": 3500,\n            \"totalPrice\": 70000\n        }\n    ],\n    \"remark\": \"年度办公设备更新计划\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/plan/annual",
              "host": ["{{baseUrl}}"],
              "path": ["plan", "annual"]
            },
            "description": "创建年度采购计划"
          }
        },
        {
          "name": "1.2 查询年度计划",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
