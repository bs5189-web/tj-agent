            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/plan/annual/:id",
              "host": ["{{baseUrl}}"],
              "path": ["plan", "annual", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PLAN-2024-001",
                  "description": "计划ID"
                }
              ]
            },
            "description": "根据ID查询年度计划详情"
          }
        },
        {
          "name": "1.3 查询计划列表",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('响应状态码为200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('返回计划列表', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
